        "id": "70",
        "folderId": "67",
        "color": "#2d70b3",
        "latex": "R_{t}=\\frac{1}{2}\\sqrt{\\left(X_{huber}\\left[i\\right]-X_{huber}\\left[i+1\\right]\\right)^{2}+\\left(h_{uber}\\left(X_{huber}\\left[i\\right]\\right)-h_{uber}\\left(X_{huber}\\left[i+1\\right]\\right)\\right)^{2}}",
        "hidden": true,
        "slider": {
          "hardMin": true,
