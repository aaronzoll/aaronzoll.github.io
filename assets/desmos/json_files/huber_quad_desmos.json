        "title": "Performance"
      },
      {
        "type": "text",
        "id": "43",
        "folderId": "40",
        "text": "Because of the indexing, the N+1 element of the array is \"x_N\""
      },
      {
        "type": "expression",
        "id": "41",
        "folderId": "40",
        "color": "#6042a6",
        "latex": "h_{uberVal}=\\operatorname{round}\\left(h_{uber}\\left(X_{huber}\\left[N+1\\right]\\right),6\\right)"
      },
      {
        "type": "expression",
        "id": "45",
        "folderId": "40",
        "color": "#2d70b3",
        "latex": "q_{uadVal}=\\operatorname{round}\\left(q_{uad}\\left(X_{quad}\\left[N+1\\right]\\right),6\\right)"
      },
      {
        "type": "expression",
        "id": "48",
        "folderId": "40",
        "color": "#6042a6",
        "latex": "w_{orstCasePerformance}\\ =\\ \\max\\left(h_{uberVal},q_{uadVal}\\right)"
